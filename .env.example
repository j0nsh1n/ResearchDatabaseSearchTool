# Copy this file to .env and fill in real values.

# REQUIRED: secret used to sign JWT auth tokens.
# The app refuses to start in production without this.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Optional: local-development flag (default false = production behaviour).
# Set DEBUG=true when running locally over plain http://localhost. Two effects:
#   1. The app will start without SECRET_KEY.
#   2. Auth cookies are NOT marked "Secure", so the browser will actually store
#      them over http. With DEBUG=false over http, login silently loops back to
#      the login page because Secure cookies are dropped on non-HTTPS origins.
# Leave it false in any HTTPS deployment (HF Spaces, Render, etc.).
DEBUG=false

# Optional: NASA ADS API token (the NASA ADS fetcher is skipped if unset).
NASA_ADS_TOKEN=

# Optional: CORE API key (the CORE fetcher is skipped if unset).
# Free key: https://core.ac.uk/services/api
CORE_API_KEY=

# Optional: force the embedding device. Leave unset to auto-detect
# (cuda > mps > cpu). Set to cpu/cuda/mps to override, e.g. EMBEDDING_DEVICE=cuda.
# NOTE: the bundled Dockerfile installs CPU-only torch; for GPU acceleration,
# install a CUDA-enabled torch build in your image/host.
EMBEDDING_DEVICE=
