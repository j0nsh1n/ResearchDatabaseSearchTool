# Copy this file to .env and fill in real values.

# REQUIRED: secret used to sign JWT auth tokens.
# The app refuses to start in production without this.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Optional: local-development flag (default false = production behaviour).
# Set DEBUG=true when running locally over plain http://localhost. Two effects:
#   1. The app will start without SECRET_KEY.
#   2. Auth cookies are NOT marked "Secure", so the browser will actually store
#      them over http. With DEBUG=false over http, login silently loops back to
#      the login page because Secure cookies are dropped on non-HTTPS origins.
# Leave it false in any HTTPS deployment (HF Spaces, Render, etc.).
DEBUG=false

# Optional: NASA ADS API token (the NASA ADS fetcher is skipped if unset).
NASA_ADS_TOKEN=


# Optional: force the embedding device. Leave unset to auto-detect
# (cuda > mps > cpu). Set to cpu/cuda/mps to override, e.g. EMBEDDING_DEVICE=cuda.
# NOTE: the bundled Dockerfile installs CPU-only torch; for GPU acceleration,
# install a CUDA-enabled torch build in your image/host.
EMBEDDING_DEVICE=

# ---------------------------------------------------------------------------
# Optional AI study aid (opt-in). Extractive key points always work without this.
# You can also configure keys + Ollama from Account → "AI study aid" (saved to
# user_data/ai_settings.json). Environment variables override the file when set.
# ---------------------------------------------------------------------------
# LLM_PROVIDER=auto|ollama|openai|anthropic
LLM_PROVIDER=auto

# Local Ollama (preferred in "auto" when OLLAMA_MODEL is set)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b
# Path used when THIS app auto-starts the built-in study aid (Refine/Ask):
# OLLAMA_MODELS=/var/mnt/games/LLM_Models
# Allow the app to start/stop the built-in local service (default true):
# AI_ALLOW_OLLAMA_CONTROL=true
#
# Allow any logged-in user to save Account → AI settings (default true).
# On multi-user shared hosts set false so only env / ai_settings.json (deployer) can change keys:
# AI_ALLOW_SETTINGS_WRITE=false

# OpenAI-compatible APIs (OpenAI, OpenRouter, Groq, Azure-compatible proxies, …)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# For OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-6

# LLM_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Classroom UI toggles (Phase R2 — high school / younger students)
# ---------------------------------------------------------------------------
# Hide search-time study-type tags (plain-language badges). Default: show.
# HIDE_STUDY_TYPE_TAGS=true
#
# Hide AI Refine/Ask buttons on Search and the Account "AI study aid" card.
# Extractive key points always remain available. Default: show when AI is configured.
# HIDE_AI_BUTTONS=true
